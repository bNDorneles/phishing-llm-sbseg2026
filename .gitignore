# Generated reports. Keep only the explanatory README in Git.
reports/CHANGELOG_EXPERIMENTOS.md
reports/0*_*.md
reports/[0-9][0-9]_*.md

# Keep folder structure in the repository
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/baseline_historico/.gitkeep
!results/.gitkeep
!reports/README.md
