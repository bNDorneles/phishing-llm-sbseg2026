# Secrets and local environment
.env
.venv/
.vscode/

# Python cache
__pycache__/
*.pyc

# Operating system and logs
.DS_Store
*.log

# Local datasets and imported archives
data/raw/*
data/processed/*
data/baseline_historico/*
*.zip
*.rar
*.csv

